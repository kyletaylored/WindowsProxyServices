<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v4 product definition for Windows Proxy Services.

  Default install path : C:\Services\WindowsProxyService
                         (matches the path used in deploy.ps1 / install-services.ps1)

  GUI install  : double-click the .msi — an install-directory dialog lets you change the path.
  Silent install (PowerShell / cmd):
      msiexec /i WindowsProxyServices-1.2.3.msi /quiet
      msiexec /i WindowsProxyServices-1.2.3.msi /quiet INSTALLFOLDER="D:\Custom\Path\"
  Uninstall:
      msiexec /x WindowsProxyServices-1.2.3.msi /quiet
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
  xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Windows Proxy Services" Manufacturer="$(var.Manufacturer)" Version="$(var.Version)" UpgradeCode="F1E2D3C4-B5A6-7890-DEAD-BEEF00000001" Scope="perMachine">

    <SummaryInformation Description="YARP-based reverse proxy Windows services for Datadog APM tracing." />

    <!-- Remove the old version automatically when upgrading; block downgrades. -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of Windows Proxy Services is already installed." />

    <!-- Embed the cabinet into the MSI so it is a single self-contained file. -->
    <MediaTemplate EmbedCab="yes" />

    <!-- App icon shown in Add/Remove Programs -->
    <Icon Id="AppIcon.ico" SourceFile="installer\app.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />
    <!-- "Comments" column in Add/Remove Programs (Programs and Features) -->
    <Property Id="ARPCOMMENTS" Value="YARP-based reverse proxy Windows services for Datadog APM tracing. Includes a web dashboard at http://localhost:5051." />

    <!--
      Directory layout:
        TARGETDIR (C:\)
          └── Services\
                └── WindowsProxyService\   ← INSTALLFOLDER

      TARGETDIR is set by Windows Installer to the root of the selected drive,
      so the default path resolves to C:\Services\WindowsProxyService.
      The WixUI_InstallDir dialog lets the user override INSTALLFOLDER to any path.
    -->
    <StandardDirectory Id="TARGETDIR">
      <Directory Id="ServicesFolder" Name="Services">
        <Directory Id="INSTALLFOLDER" Name="WindowsProxyService" />
      </Directory>
      <!-- All-users Startup folder — not in WiX v4's StandardDirectory allow-list,
           so declared as a plain Directory; MSI resolves it to the system path. -->
      <Directory Id="CommonStartupFolder" />
    </StandardDirectory>
    <!-- Required to place the tray app shortcut in the Start Menu -->
    <StandardDirectory Id="ProgramMenuFolder" />

    <!-- Standard install-directory UI. -->
    <ui:WixUI Id="WixUI_InstallDir" />
    <!--
      Pull in the named UI block from RumConfigDlg.wxs so the linker does not
      trim it.  That block contains the <Publish> overrides that insert
      RumConfigDlg between InstallDirDlg and VerifyReadyDlg.
    -->
    <UIRef Id="WixUI_InstallDir_RUM" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="installer\License.rtf" />

    <!--
      Custom UI graphics — replace the default WiX placeholders.  Both are required to avoid linker warnings.
      Sizing notes:
      Banner : 493 × 58  px BMP — top strip shown on all interior dialog pages.
      Dialog : 493 × 312 px BMP — left panel on the Welcome and Exit dialogs.
    -->

    <WixVariable Id="WixUIBannerBmp" Value="installer\banner.bmp" />
    <WixVariable Id="WixUIDialogBmp" Value="installer\dialog.bmp" />


    <!-- ── Datadog RUM installer properties ────────────────────────────── -->
    <!--
      Collected by RumConfigDlg and written to HKLM\SOFTWARE\WindowsProxyServices\RUM. Secure="yes" passes them from the UI layer to the elevated execute sequence.
      Can also be supplied on the command line for silent/automated installs:
        msiexec /i ... /quiet DD_RUM_APP_ID="..." DD_RUM_CLIENT_TOKEN="..." DD_RUM_SITE="us3.datadoghq.com" DD_RUM_ENV="prod"
    -->
    <Property Id="DD_RUM_APP_ID" Secure="yes" />
    <Property Id="DD_RUM_CLIENT_TOKEN" Secure="yes" />
    <Property Id="DD_RUM_SITE" Value="datadoghq.com" Secure="yes" />
    <Property Id="DD_RUM_ENV" Secure="yes" />

    <!-- ── Launch on exit ──────────────────────────────────────────────── -->
    <!--
      WIXUI_EXITDIALOGOPTIONALCHECKBOX shows a checkbox on the final dialog.
      Setting it to "1" means checked by default. Secure="yes" ensures the property is passed from the UI layer to the
      elevated execute sequence so the condition on LaunchTrayApp works.
    -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" Secure="yes" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Windows Proxy Services tray app" />

    <!--
      Fire-and-forget: launch the tray app after the installer completes. FileRef="FileTrayExe" resolves to the installed WindowsTrayApp.exe.
      asyncNoWait lets the installer exit without waiting for the tray app.
      Condition: checkbox is checked AND this is not an uninstall.
    -->
    <CustomAction Id="LaunchTrayApp" FileRef="FileTrayExe" ExeCommand="" Execute="immediate" Return="asyncNoWait" Impersonate="yes" />

    <InstallExecuteSequence>
      <Custom Action="LaunchTrayApp" After="InstallFinalize" Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT REMOVE" />
    </InstallExecuteSequence>

    <Feature Id="ProductFeature" Title="Windows Proxy Services" Level="1">
      <!-- All runtime files (DLLs, services.json, …) — generated at build time -->
      <ComponentGroupRef Id="ProductComponents" />
      <!-- WindowsProxyService.exe + all five Windows service registrations -->
      <ComponentGroupRef Id="ServiceComponents" />
    </Feature>

  </Package>
</Wix>
