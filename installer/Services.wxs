<?xml version="1.0" encoding="UTF-8"?>
<!--
  All five proxy Windows services are defined in a single MSI component that
  owns WindowsProxyService.exe as its KeyPath.

  Why one component for all services?
    Windows Installer derives each service's ImagePath from the component's
    install directory + KeyPath filename.  Keeping the exe as KeyPath in the
    same component as the ServiceInstall elements guarantees that every service
    gets the correct binary path automatically, e.g.:
        "C:\Services\WindowsProxyService\WindowsProxyService.exe" -name OpenMeteo

  DD environment variables (DD_SERVICE, DD_VERSION) are written to each
  service's registry key so the Datadog agent can correlate traces.
  The [~] separator is WiX syntax for a REG_MULTI_SZ null delimiter.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>

    <ComponentGroup Id="ServiceComponents" Directory="INSTALLFOLDER">

      <Component Id="CompServices" Guid="C0FFEE00-1234-5678-ABCD-EF0123456789">

        <!-- Executable — must be KeyPath so MSI resolves the service ImagePath correctly. -->
        <File Id="FileExe"
              Source="$(var.PublishDir)\WindowsProxyService.exe"
              KeyPath="yes" />

        <!-- ═══════════════════════════════════════════════════════════════════
             OpenMeteo  |  port 5052  |  https://api.open-meteo.com
        ════════════════════════════════════════════════════════════════════ -->
        <ServiceInstall
          Id="SvcOpenMeteoInstall"
          Name="WindowsProxyService.OpenMeteo"
          DisplayName="Windows Proxy Service - OpenMeteo"
          Description="Proxies requests to the Open-Meteo weather forecast API (no auth required)"
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal"
          Arguments="--name OpenMeteo" />
        <ServiceControl
          Id="SvcOpenMeteoStart"
          Name="WindowsProxyService.OpenMeteo"
          Start="install"
          Wait="no" />
        <ServiceControl
          Id="SvcOpenMeteoStop"
          Name="WindowsProxyService.OpenMeteo"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
        <RegistryKey Root="HKLM"
          Key="SYSTEM\CurrentControlSet\Services\WindowsProxyService.OpenMeteo">
          <RegistryValue Name="Environment" Type="multiString"
            Value="DD_SERVICE=windowsproxyservice-openmeteo[~]DD_VERSION=$(var.Version)" />
        </RegistryKey>

        <!-- ═══════════════════════════════════════════════════════════════════
             CatFacts  |  port 5053  |  https://catfact.ninja
        ════════════════════════════════════════════════════════════════════ -->
        <ServiceInstall
          Id="SvcCatFactsInstall"
          Name="WindowsProxyService.CatFacts"
          DisplayName="Windows Proxy Service - CatFacts"
          Description="Proxies requests to the Cat Facts API (no auth required)"
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal"
          Arguments="--name CatFacts" />
        <ServiceControl
          Id="SvcCatFactsStart"
          Name="WindowsProxyService.CatFacts"
          Start="install"
          Wait="no" />
        <ServiceControl
          Id="SvcCatFactsStop"
          Name="WindowsProxyService.CatFacts"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
        <RegistryKey Root="HKLM"
          Key="SYSTEM\CurrentControlSet\Services\WindowsProxyService.CatFacts">
          <RegistryValue Name="Environment" Type="multiString"
            Value="DD_SERVICE=windowsproxyservice-catfacts[~]DD_VERSION=$(var.Version)" />
        </RegistryKey>

        <!-- ═══════════════════════════════════════════════════════════════════
             JsonPlaceholder  |  port 5054  |  https://jsonplaceholder.typicode.com
        ════════════════════════════════════════════════════════════════════ -->
        <ServiceInstall
          Id="SvcJsonPlaceholderInstall"
          Name="WindowsProxyService.JsonPlaceholder"
          DisplayName="Windows Proxy Service - JsonPlaceholder"
          Description="Proxies requests to JSONPlaceholder — fake REST API for testing (no auth required)"
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal"
          Arguments="--name JsonPlaceholder" />
        <ServiceControl
          Id="SvcJsonPlaceholderStart"
          Name="WindowsProxyService.JsonPlaceholder"
          Start="install"
          Wait="no" />
        <ServiceControl
          Id="SvcJsonPlaceholderStop"
          Name="WindowsProxyService.JsonPlaceholder"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
        <RegistryKey Root="HKLM"
          Key="SYSTEM\CurrentControlSet\Services\WindowsProxyService.JsonPlaceholder">
          <RegistryValue Name="Environment" Type="multiString"
            Value="DD_SERVICE=windowsproxyservice-jsonplaceholder[~]DD_VERSION=$(var.Version)" />
        </RegistryKey>

        <!-- ═══════════════════════════════════════════════════════════════════
             DogCeo  |  port 5055  |  https://dog.ceo
        ════════════════════════════════════════════════════════════════════ -->
        <ServiceInstall
          Id="SvcDogCeoInstall"
          Name="WindowsProxyService.DogCeo"
          DisplayName="Windows Proxy Service - DogCeo"
          Description="Proxies requests to the Dog CEO random dog image API (no auth required)"
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal"
          Arguments="--name DogCeo" />
        <ServiceControl
          Id="SvcDogCeoStart"
          Name="WindowsProxyService.DogCeo"
          Start="install"
          Wait="no" />
        <ServiceControl
          Id="SvcDogCeoStop"
          Name="WindowsProxyService.DogCeo"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
        <RegistryKey Root="HKLM"
          Key="SYSTEM\CurrentControlSet\Services\WindowsProxyService.DogCeo">
          <RegistryValue Name="Environment" Type="multiString"
            Value="DD_SERVICE=windowsproxyservice-dogceo[~]DD_VERSION=$(var.Version)" />
        </RegistryKey>

        <!-- ═══════════════════════════════════════════════════════════════════
             ChuckNorris  |  port 5056  |  https://api.chucknorris.io
        ════════════════════════════════════════════════════════════════════ -->
        <ServiceInstall
          Id="SvcChuckNorrisInstall"
          Name="WindowsProxyService.ChuckNorris"
          DisplayName="Windows Proxy Service - ChuckNorris"
          Description="Proxies requests to the Chuck Norris jokes API (no auth required)"
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal"
          Arguments="--name ChuckNorris" />
        <ServiceControl
          Id="SvcChuckNorrisStart"
          Name="WindowsProxyService.ChuckNorris"
          Start="install"
          Wait="no" />
        <ServiceControl
          Id="SvcChuckNorrisStop"
          Name="WindowsProxyService.ChuckNorris"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
        <RegistryKey Root="HKLM"
          Key="SYSTEM\CurrentControlSet\Services\WindowsProxyService.ChuckNorris">
          <RegistryValue Name="Environment" Type="multiString"
            Value="DD_SERVICE=windowsproxyservice-chucknorris[~]DD_VERSION=$(var.Version)" />
        </RegistryKey>

      </Component>

      <!-- ═══════════════════════════════════════════════════════════════════
           Dashboard Service  |  port 5051  |  http://localhost:5051
           Serves the Bootstrap 5 web dashboard + REST API for
           status checking and service start/stop control.
      ════════════════════════════════════════════════════════════════════ -->
      <Component Id="CompDashboard" Guid="D4580001-0000-0000-0000-000000000001">
        <File Id="FileDashExe"
              Source="$(var.PublishDir)\WindowsDashboardService.exe"
              KeyPath="yes" />
        <ServiceInstall
          Id="SvcDashInstall"
          Name="WindowsDashboardService"
          DisplayName="Windows Dashboard Service"
          Description="Web dashboard for monitoring and testing the proxy services (http://localhost:5051)"
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal" />
        <ServiceControl
          Id="SvcDashStart"
          Name="WindowsDashboardService"
          Start="install"
          Wait="no" />
        <ServiceControl
          Id="SvcDashStop"
          Name="WindowsDashboardService"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
      </Component>

      <!-- ═══════════════════════════════════════════════════════════════════
           Tray Application  (WinForms exe, not a Windows service)
           A Start Menu shortcut is created so users can launch it manually.
      ════════════════════════════════════════════════════════════════════ -->
      <Component Id="CompTrayApp" Guid="D4580001-0000-0000-0000-000000000002">
        <File Id="FileTrayExe"
              Source="$(var.PublishDir)\WindowsTrayApp.exe"
              KeyPath="yes" />
        <!-- Start Menu shortcut (launch manually) -->
        <Shortcut
          Id="ShortcutTray"
          Directory="ProgramMenuFolder"
          Name="Windows Proxy Services Tray"
          WorkingDirectory="INSTALLFOLDER"
          Icon="AppIcon.ico"
          Description="System tray manager — open the dashboard, start/stop services" />
        <!-- All-users Startup folder — auto-launches the tray app for every user at login -->
        <Shortcut
          Id="ShortcutTrayStartup"
          Directory="CommonStartupFolder"
          Name="Windows Proxy Services Tray"
          WorkingDirectory="INSTALLFOLDER"
          Icon="AppIcon.ico"
          Description="System tray manager — open the dashboard, start/stop services" />
      </Component>

    </ComponentGroup>

  </Fragment>
</Wix>
