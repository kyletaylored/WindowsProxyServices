<?xml version="1.0" encoding="UTF-8"?>
<!--
  All proxy Windows services are defined in a single MSI component that
  owns WindowsProxyService.exe as its KeyPath.

  Why one component for all services?
    Windows Installer derives each service's ImagePath from the component's
    install directory + KeyPath filename.  Keeping the exe as KeyPath in the
    same component as the ServiceInstall elements guarantees that every service
    gets the correct binary path automatically, e.g.:
        "C:\Services\WindowsProxyService\WindowsProxyService.exe" -name OpenMeteo

  DD environment variables (DD_SERVICE, DD_VERSION) are written to each
  service's registry key so the Datadog agent can correlate traces.
  The [~] separator is WiX syntax for a REG_MULTI_SZ null delimiter.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>

    <ComponentGroup Id="ServiceComponents" Directory="INSTALLFOLDER">

      <Component Id="CompServices" Guid="C0FFEE00-1234-5678-ABCD-EF0123456789">

        <!-- Executable — must be KeyPath so MSI resolves the service ImagePath correctly. -->
        <File Id="FileExe"
              Source="$(var.PublishDir)\WindowsProxyService.exe"
              KeyPath="yes" />

        <!-- ═══════════════════════════════════════════════════════════════════
             OpenMeteo  |  port 5052  |  https://api.open-meteo.com
        ════════════════════════════════════════════════════════════════════ -->
        <ServiceInstall
          Id="SvcOpenMeteoInstall"
          Name="WindowsProxyService.OpenMeteo"
          DisplayName="Windows Proxy Service - OpenMeteo"
          Description="Proxies requests to the Open-Meteo weather forecast API (no auth required)"
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal"
          Arguments="--name OpenMeteo" />
        <ServiceControl
          Id="SvcOpenMeteoStart"
          Name="WindowsProxyService.OpenMeteo"
          Start="install"
          Wait="no" />
        <ServiceControl
          Id="SvcOpenMeteoStop"
          Name="WindowsProxyService.OpenMeteo"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
        <RegistryKey Root="HKLM"
          Key="SYSTEM\CurrentControlSet\Services\WindowsProxyService.OpenMeteo">
          <RegistryValue Name="Environment" Type="multiString"
            Value="DD_SERVICE=windowsproxyservice-openmeteo[~]DD_VERSION=$(var.Version)" />
        </RegistryKey>

        <!-- ═══════════════════════════════════════════════════════════════════
             JsonPlaceholder  |  port 5053  |  https://jsonplaceholder.typicode.com
        ════════════════════════════════════════════════════════════════════ -->
        <ServiceInstall
          Id="SvcJsonPlaceholderInstall"
          Name="WindowsProxyService.JsonPlaceholder"
          DisplayName="Windows Proxy Service - JsonPlaceholder"
          Description="Proxies requests to JSONPlaceholder — fake REST API for testing (no auth required)"
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal"
          Arguments="--name JsonPlaceholder" />
        <ServiceControl
          Id="SvcJsonPlaceholderStart"
          Name="WindowsProxyService.JsonPlaceholder"
          Start="install"
          Wait="no" />
        <ServiceControl
          Id="SvcJsonPlaceholderStop"
          Name="WindowsProxyService.JsonPlaceholder"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
        <RegistryKey Root="HKLM"
          Key="SYSTEM\CurrentControlSet\Services\WindowsProxyService.JsonPlaceholder">
          <RegistryValue Name="Environment" Type="multiString"
            Value="DD_SERVICE=windowsproxyservice-jsonplaceholder[~]DD_VERSION=$(var.Version)" />
        </RegistryKey>

        <!-- ═══════════════════════════════════════════════════════════════════
             DatadogDemo  |  port 5054  |  https://datadog-sanity-vercel-demo-app.vercel.app
        ════════════════════════════════════════════════════════════════════ -->
        <ServiceInstall
          Id="SvcDatadogDemoInstall"
          Name="WindowsProxyService.DatadogDemo"
          DisplayName="Windows Proxy Service - DatadogDemo"
          Description="Proxies requests to the Datadog sanity demo app — health checks, slow queries, distributed traces, and error simulation"
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal"
          Arguments="--name DatadogDemo" />
        <ServiceControl
          Id="SvcDatadogDemoStart"
          Name="WindowsProxyService.DatadogDemo"
          Start="install"
          Wait="no" />
        <ServiceControl
          Id="SvcDatadogDemoStop"
          Name="WindowsProxyService.DatadogDemo"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
        <RegistryKey Root="HKLM"
          Key="SYSTEM\CurrentControlSet\Services\WindowsProxyService.DatadogDemo">
          <RegistryValue Name="Environment" Type="multiString"
            Value="DD_SERVICE=windowsproxyservice-datadogdemo[~]DD_VERSION=$(var.Version)" />
        </RegistryKey>

      </Component>

      <!-- ═══════════════════════════════════════════════════════════════════
           Dashboard Service  |  port 5051  |  http://localhost:5051
           Serves the Bootstrap 5 web dashboard + REST API for
           status checking and service start/stop control.
      ════════════════════════════════════════════════════════════════════ -->
      <Component Id="CompDashboard" Guid="D4580001-0000-0000-0000-000000000001">
        <File Id="FileDashExe"
              Source="$(var.PublishDir)\WindowsDashboardService.exe"
              KeyPath="yes" />
        <ServiceInstall
          Id="SvcDashInstall"
          Name="WindowsDashboardService"
          DisplayName="Windows Proxy Service - Dashboard"
          Description="Web dashboard for monitoring and testing the proxy services (http://localhost:5051)"
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal" />
        <ServiceControl
          Id="SvcDashStart"
          Name="WindowsDashboardService"
          Start="install"
          Wait="no" />
        <ServiceControl
          Id="SvcDashStop"
          Name="WindowsDashboardService"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />

        <!--
          RUM configuration — written from values collected in RumConfigDlg.
          WindowsDashboardService reads these on startup and regenerates
          wwwroot/rum-config.json so the browser dashboard picks them up.
          All values are empty strings when the user leaves the dialog blank.
        -->
        <RegistryKey Root="HKLM" Key="SOFTWARE\WindowsProxyServices\RUM">
          <RegistryValue Name="ApplicationId" Type="string" Value="[DD_RUM_APP_ID]"       />
          <RegistryValue Name="ClientToken"   Type="string" Value="[DD_RUM_CLIENT_TOKEN]" />
          <RegistryValue Name="Site"          Type="string" Value="[DD_RUM_SITE]"         />
          <RegistryValue Name="Env"           Type="string" Value="[DD_RUM_ENV]"          />
        </RegistryKey>
      </Component>

      <!-- ═══════════════════════════════════════════════════════════════════
           SQL Service  |  port 5055  |  sql://localhost\SQLEXPRESS/WpsDemo
           Exposes a WpsDemo SQL Server database (Products / Orders / Customers)
           for Datadog DBM and SQL tracing demos.
           DD_DBM_PROPAGATION_MODE=full enables trace-to-query correlation.
      ════════════════════════════════════════════════════════════════════ -->
      <Component Id="CompSqlService" Guid="D4580001-0000-0000-0000-000000000003">
        <File Id="FileSqlExe"
              Source="$(var.PublishDir)\WindowsSqlService.exe"
              KeyPath="yes" />
        <ServiceInstall
          Id="SvcSqlInstall"
          Name="WindowsSqlService"
          DisplayName="Windows Proxy Service - SQL Service"
          Description="Exposes a WpsDemo SQL Server database for Datadog DBM and SQL tracing demos (http://localhost:5055)"
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal" />
        <ServiceControl
          Id="SvcSqlStart"
          Name="WindowsSqlService"
          Start="install"
          Wait="no" />
        <ServiceControl
          Id="SvcSqlStop"
          Name="WindowsSqlService"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
        <RegistryKey Root="HKLM"
          Key="SYSTEM\CurrentControlSet\Services\WindowsSqlService">
          <RegistryValue Name="Environment" Type="multiString"
            Value="DD_SERVICE=windowssqlservice[~]DD_VERSION=$(var.Version)[~]DD_DBM_PROPAGATION_MODE=full" />
        </RegistryKey>
      </Component>

      <!-- ═══════════════════════════════════════════════════════════════════
           Tray Application  (WinForms exe, not a Windows service)
           A Start Menu shortcut is created so users can launch it manually.
      ════════════════════════════════════════════════════════════════════ -->
      <Component Id="CompTrayApp" Guid="D4580001-0000-0000-0000-000000000002">
        <File Id="FileTrayExe"
              Source="$(var.PublishDir)\WindowsTrayApp.exe"
              KeyPath="yes" />
        <!-- Start Menu shortcut (launch manually) -->
        <Shortcut
          Id="ShortcutTray"
          Directory="ProgramMenuFolder"
          Name="Windows Proxy Services Tray"
          WorkingDirectory="INSTALLFOLDER"
          Icon="AppIcon.ico"
          Description="System tray manager — open the dashboard, start/stop services" />
        <!-- All-users Startup folder — auto-launches the tray app for every user at login -->
        <Shortcut
          Id="ShortcutTrayStartup"
          Directory="CommonStartupFolder"
          Name="Windows Proxy Services Tray"
          WorkingDirectory="INSTALLFOLDER"
          Icon="AppIcon.ico"
          Description="System tray manager — open the dashboard, start/stop services" />
      </Component>

    </ComponentGroup>

  </Fragment>
</Wix>
