<?xml version="1.0" encoding="UTF-8"?>
<!--
  Optional Datadog RUM configuration dialog.
  Inserted between InstallDirDlg and VerifyReadyDlg in the WixUI_InstallDir sequence.

  Values collected here are written to:
    HKLM\SOFTWARE\WindowsProxyServices\RUM
  by the RegistryKey in Services.wxs.

  On first startup, WindowsDashboardService reads those registry values and
  regenerates wwwroot/rum-config.json so the browser dashboard picks them up.

  All fields are optional — leave blank to disable RUM.

  WiX v4 syntax notes:
    - <Text> uses Value="..." attribute (inner text is obsolete)
    - <Publish> uses Condition="..." attribute (inner text is obsolete)
    - <ListItem> has no Order attribute; ordering is positional
    - Dialog sequence overrides go inside <UI> as direct <Publish> children;
      use a high Order (9999) to ensure they fire after the built-in transitions.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <!--
      Give this UI block a named Id so the WiX v4 linker does not trim it as an
      unreferenced symbol.  Product.wxs pulls it in with <UIRef Id="WixUI_InstallDir_RUM" />.
      Without the Id + UIRef pair, the <Publish> rows below are silently absent
      from the MSI's ControlEvent table and the dialog never appears in the wizard.
    -->
    <UI Id="WixUI_InstallDir_RUM">

      <!-- ── Dialog definition ──────────────────────────────────────────── -->
      <Dialog Id="RumConfigDlg" Width="370" Height="270" Title="[ProductName] Setup">

        <!-- Banner (same style as built-in WiX dialogs) -->
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44"
                 TabSkip="yes" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine"   Type="Line"   X="0" Y="44" Width="370" Height="0" />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15"
                 Transparent="yes" NoPrefix="yes">
          <Text Value="{\WixUI_Font_Title}Datadog RUM Configuration" />
        </Control>
        <Control Id="Description" Type="Text" X="25" Y="23" Width="330" Height="15"
                 Transparent="yes" NoPrefix="yes">
          <Text Value="Configure browser monitoring for the dashboard (optional). Leave blank to disable." />
        </Control>

        <!-- Application ID -->
        <Control Id="AppIdLabel" Type="Text" X="20" Y="54" Width="330" Height="10" NoPrefix="yes">
          <Text Value="Application ID:" />
        </Control>
        <Control Id="AppIdEdit" Type="Edit" X="20" Y="66" Width="330" Height="18"
                 Property="DD_RUM_APP_ID" Text="{80}" TabSkip="no" />

        <!-- Client Token -->
        <Control Id="ClientTokenLabel" Type="Text" X="20" Y="90" Width="330" Height="10" NoPrefix="yes">
          <Text Value="Client Token:" />
        </Control>
        <Control Id="ClientTokenEdit" Type="Edit" X="20" Y="102" Width="330" Height="18"
                 Property="DD_RUM_CLIENT_TOKEN" Text="{80}" TabSkip="no" />

        <!-- Site (dropdown) -->
        <Control Id="SiteLabel" Type="Text" X="20" Y="126" Width="80" Height="10" NoPrefix="yes">
          <Text Value="Site:" />
        </Control>
        <Control Id="SiteCombo" Type="ComboBox" X="20" Y="138" Width="210" Height="60"
                 Property="DD_RUM_SITE" ComboList="yes" TabSkip="no" />

        <!-- Environment -->
        <Control Id="EnvLabel" Type="Text" X="20" Y="164" Width="330" Height="10" NoPrefix="yes">
          <Text Value="Environment (e.g. prod, staging, dev):" />
        </Control>
        <Control Id="EnvEdit" Type="Edit" X="20" Y="176" Width="150" Height="18"
                 Property="DD_RUM_ENV" Text="{30}" TabSkip="no" />

        <!-- SQL Server Express notice -->
        <Control Id="SqlNote" Type="Text" X="20" Y="212" Width="330" Height="18" NoPrefix="yes">
          <Text Value="{\WixUI_Font_Normal}SQL Server Express will be installed automatically if not already present on this machine." />
        </Control>

        <!-- Bottom line + navigation buttons -->
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17"
                 Text="!(loc.WixUIBack)">
          <Publish Event="NewDialog" Value="InstallDirDlg" Condition="1" />
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17"
                 Default="yes" Text="!(loc.WixUINext)">
          <Publish Event="NewDialog" Value="VerifyReadyDlg" Condition="1" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17"
                 Cancel="yes" Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg" Condition="1" />
        </Control>
      </Dialog>

      <!-- ComboBox items for the site selector (order is positional in WiX v4) -->
      <ComboBox Property="DD_RUM_SITE">
        <ListItem Text="datadoghq.com (US1)"     Value="datadoghq.com"     />
        <ListItem Text="us3.datadoghq.com (US3)" Value="us3.datadoghq.com" />
        <ListItem Text="us5.datadoghq.com (US5)" Value="us5.datadoghq.com" />
        <ListItem Text="datadoghq.eu (EU1)"      Value="datadoghq.eu"      />
        <ListItem Text="ap1.datadoghq.com (AP1)" Value="ap1.datadoghq.com" />
        <ListItem Text="ddog-gov.com (US1-FED)"  Value="ddog-gov.com"      />
      </ComboBox>

      <!--
        Wire this dialog into the WixUI_InstallDir sequence.
        The built-in InstallDirDlg Next→VerifyReadyDlg transition uses Order=4.
        Order=9999 guarantees our NewDialog fires last and wins — MSI uses the
        last-queued NewDialog value after all ControlEvent rows have been evaluated.

        Conditions mirror the built-in so the dialog only appears when appropriate:
          InstallDirDlg Next: only when the path is valid (or validation is skipped)
          VerifyReadyDlg Back: only during a fresh install (not repair/remove)
      -->
      <Publish Dialog="InstallDirDlg"  Control="Next" Event="NewDialog" Value="RumConfigDlg" Order="9999"
               Condition="WIXUI_DONTVALIDATEPATH OR WIXUI_INSTALLDIR_VALID=&quot;1&quot;" />
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="RumConfigDlg" Order="9999"
               Condition="NOT Installed" />

    </UI>
  </Fragment>
</Wix>
